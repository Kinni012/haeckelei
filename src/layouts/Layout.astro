---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Haeckelei – meine Website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <script is:inline>
      (() => {
        // Mobile back-button / back-gesture handling:
        // - If scrolled down, pressing Back should jump to absolute top (0,0) and stay.
        // - If already at absolute top, pressing Back should leave normally.
        //
        // On some browsers, navigating away and back restores the page from a
        // back/forward cache without re-running scripts. To keep behavior
        // consistent, we (re)initialize the handler on page show.

        function ensureSentinelEntry() {
          const st = history.state;
          const hasSentinel = !!(st && typeof st === 'object' && st.__backTopSentinel === true);
          if (hasSentinel) return;
          try {
            history.pushState({ __backTopSentinel: true }, '', location.href);
          } catch {
            // Ignore environments where history state is unavailable.
          }
        }

        function initBackScrollHandler() {
          if (window.__backScrollHandlerInitialized) return;
          window.__backScrollHandlerInitialized = true;

          // Ensure we have a duplicate entry to intercept Back.
          ensureSentinelEntry();

          let isAutoExiting = false;

          window.addEventListener('popstate', () => {
            if (isAutoExiting) {
              isAutoExiting = false;
              return;
            }

            const scrollY = window.scrollY || 0;
            const atTop = scrollY <= 1;

            if (!atTop) {
              // Always jump fully to the very top (no smooth scrolling).
              const doc = document.documentElement;
              const body = document.body;
              if (doc) doc.scrollTop = 0;
              if (body) body.scrollTop = 0;
              window.scrollTo(0, 0);

              // Stay on this page by restoring the sentinel entry.
              // (Defer a tick to avoid some mobile browsers ignoring pushState
              // during the same event turn.)
              setTimeout(() => ensureSentinelEntry(), 0);
              return;
            }

            // At the very top: leave immediately (no "double back").
            // At this point we've just popped from our sentinel entry to the
            // previous entry. Trigger one more Back to actually leave.
            isAutoExiting = true;
            history.back();
          });
        }

        initBackScrollHandler();
        // Re-arm when returning from bfcache or history restores.
        // (Do it async: some browsers ignore pushState inside pageshow.)
        window.addEventListener('pageshow', () => {
          setTimeout(() => ensureSentinelEntry(), 0);
        });
      })();
    </script>
  </body>
</html>


